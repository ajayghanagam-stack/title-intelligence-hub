# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION - AWS DEPLOYMENT
# =============================================================================
# Copy this file to .env and fill in your production values
# NEVER commit this file with real credentials to version control
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string (RDS recommended for production)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_STRONG_PASSWORD@your-rds-instance.region.rds.amazonaws.com:5432/title_intelligence_hub

# -----------------------------------------------------------------------------
# SECURITY (Required - CHANGE THESE!)
# -----------------------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=GENERATE_A_STRONG_64_CHAR_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# MUST be false in production
DEBUG=false

# -----------------------------------------------------------------------------
# CORS (Required)
# -----------------------------------------------------------------------------
# Your production frontend URL(s)
CORS_ORIGINS=["https://your-production-domain.com","https://www.your-production-domain.com"]

# -----------------------------------------------------------------------------
# STORAGE - AWS S3 (Recommended for production)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=s3
S3_BUCKET=your-title-intelligence-bucket
S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_ID
S3_SECRET_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_REGION=us-east-1
# Leave S3_ENDPOINT empty for AWS S3 (set only for MinIO/other S3-compatible storage)
S3_ENDPOINT=

# Maximum file upload size (100 MB default)
FILE_UPLOAD_MAX_SIZE=104857600

# -----------------------------------------------------------------------------
# AI PROVIDER (Required)
# -----------------------------------------------------------------------------
AI_PROVIDER=gemini
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# Alternative: Use Claude instead of Gemini
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# -----------------------------------------------------------------------------
# PIPELINE CONFIGURATION
# -----------------------------------------------------------------------------
# Use background_tasks for simple deployments, temporal for high-volume
PIPELINE_BACKEND=background_tasks
PIPELINE_MODE=native_pdf

# For Temporal workflow orchestration (optional, for high-volume processing)
# PIPELINE_BACKEND=temporal
# TEMPORAL_ADDRESS=your-temporal-server:7233
# TEMPORAL_NAMESPACE=production
# TEMPORAL_TASK_QUEUE=title-intelligence

# -----------------------------------------------------------------------------
# PERFORMANCE TUNING (Adjust based on your server specs)
# -----------------------------------------------------------------------------
# Native PDF processing
NATIVE_PDF_BATCH_SIZE=20
NATIVE_PDF_CONCURRENCY=12
NATIVE_PDF_STAGGER_MS=0

# Page triage
TRIAGE_ENABLED=true
TRIAGE_SKIP_BELOW=80
TRIAGE_CHUNK_SIZE=50
TRIAGE_CONCURRENCY=4

# Document grouping
GROUPING_ENABLED=true
ADAPTIVE_CHUNK_SIZING=true
SPECIALIZED_EXTRACTION_ENABLED=true

# Summary generation
SUMMARY_MODE=data_driven

# Examiner settings (adjust for your AI provider rate limits)
EXAMINER_BATCH_SIZE=10
EXAMINER_BATCH_SIZE_TEXT=25
EXAMINER_RENDER_DPI=72
EXAMINER_CALL_TIMEOUT=300
EXAMINER_MAX_OUTPUT_TOKENS=65536
