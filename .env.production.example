# Domain — Caddy uses this for auto-SSL via Let's Encrypt
DOMAIN=app.logikality.com

# PostgreSQL
POSTGRES_DB=title_intelligence_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Authentication
JWT_SECRET=change-me-strong-secret

# AI
ANTHROPIC_API_KEY=sk-ant-api03-...
AI_PLATFORM=anthropic

# Storage
STORAGE_PROVIDER=local
STORAGE_PATH=/app/storage

# Pipeline
PIPELINE_BACKEND=background_tasks

# CORS (auto-set from DOMAIN in docker-compose.prod.yml, override if needed)
# CORS_ORIGINS=["https://app.logikality.com"]

# Debug
DEBUG=false

# Docker image tag (set by CI/CD, or use "latest")
IMAGE_TAG=latest

# GitHub Container Registry repo (auto-set in CI, override for manual deploy)
# GITHUB_REPOSITORY=logikality/title-intelligence-hub
